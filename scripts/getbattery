#!/bin/bash

# Buscamos dinámicamente cualquier carpeta de batería que empiece con BAT
BAT_PATH=$(ls -d /sys/class/power_supply/BAT* 2>/dev/null | head -n 1)

# Si el sistema encuentra una batería, lee su capacidad actual
if [ -n "$BAT_PATH" ] && [ -f "$BAT_PATH/capacity" ]; then
    cat "$BAT_PATH/capacity"
else
    # Si es una PC de escritorio, devuelve 100 por defecto de forma segura
    echo "100"
fi